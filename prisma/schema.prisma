generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ParticipantLog {
  id                   Int      @id @default(autoincrement())

  participantId        String   @unique
  group                String

  // demographics
  age                  Int?
  gender               String?
  education            String?
  deviceType           String?

  confidence           Int?

  pretestQ1            Int?
  pretestQ2            Int?
  pretestQ3            Int?
  pretestQ4            Int?
  pretestScore         Int?

  posttestQ1           Int?
  posttestQ2           Int?
  posttestQ3           Int?
  posttestQ4           Int?
  posttestScore        Int?

  // chat analytics
  chatTranscript       String?
  chatMessageCount     Int?
  userMessageCount     Int?
  assistantMessageCount Int?

  // EVT (Expectancy-Value Theory, 1-4)
  evt1                 Int?
  evt2                 Int?
  evt3                 Int?

  // free text
  freeTextResponse     String?
  freeTextWordCount    Int?

  // perceived learning
  perceivedLearning1   Int?
  easeOfConversating1  Int?
  adaptingToNeeds1     Int?

  // mental effort (Paas, 1-9)
  mentalEffort         Int?

  // completion tracking
  completed            Boolean  @default(false)
  dropoutStep          String?

  // timing (ms)
  readingTime          Int?
  chatDuration         Int?

  // follow-up system
  email                String?
  followUpToken        String?  @unique
  followUpDeviceType   String?

  // follow-up study results
  followUpCompleted         Boolean   @default(false)
  followUpCompletedAt       DateTime?
  followUpFreeText          String?
  followUpFreeTextWordCount Int?

  createdAt            DateTime @default(now())
  updatedAt            DateTime? @updatedAt
}